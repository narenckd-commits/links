<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Adv. Narender Mudgil | Social Media Links</title>

<style>
    *{
        margin:0;
        padding:0;
        box-sizing:border-box;
        font-family: Arial, sans-serif;
    }

    body{
        background: linear-gradient(135deg,#0a3d62,#1e3799);
        min-height:100vh;
        display:flex;
        justify-content:center;
        align-items:center;
        padding:20px;
    }

    .container{
        width:100%;
        max-width:500px;
        background:#fff;
        border-radius:20px;
        padding:30px;
        text-align:center;
        box-shadow:0 10px 30px rgba(0,0,0,0.2);
    }

    .profile-img{
        width:120px;
        height:120px;
        border-radius:50%;
        object-fit:cover;
        border:4px solid #1e3799;
        margin-bottom:15px;
    }

    h1{
        color:#1e3799;
        font-size:28px;
        margin-bottom:5px;
    }

    .designation{
        color:#444;
        font-size:18px;
        font-weight:bold;
    }

    .ward{
        color:#666;
        margin-bottom:25px;
    }

    .link-btn{
        display:block;
        text-decoration:none;
        color:white;
        padding:15px;
        margin:12px 0;
        border-radius:12px;
        font-size:18px;
        font-weight:bold;
        transition:0.3s;
    }

    .link-btn:hover{
        transform:scale(1.03);
    }

    .facebook{background:#1877F2;}
    .instagram{background:#E4405F;}
    .youtube{background:#FF0000;}
    .twitter{background:#000000;}
    .whatsapp-channel{background:#25D366;}
    .whatsapp-community{background:#128C7E;}
    .threads{background:#111111;}

    footer{
        margin-top:20px;
        color:#666;
        font-size:14px;
    }
</style>
</head>

<body>

<div class="container">

    <!-- Replace image URL with your photo -->
    <img src="your-photo.jpg" alt="Block Congress Committee Delhi" class="profile-img">

    <h1>Adv. Narender Mudgil</h1>

    <div class="designation">
        BCC President
    </div>

    <div class="ward">
        Nangli Sakrawati Ward - 124
    </div>

    <a class="link-btn facebook"
       href="https://www.facebook.com/NarenderMudgilINC"
       target="_blank">
       Facebook
    </a>

    <a class="link-btn instagram"
       href="https://www.instagram.com/adv.narendersh/"
       target="_blank">
       Instagram
    </a>

    <a class="link-btn youtube"
       href="https://www.youtube.com/@narendersh"
       target="_blank">
       YouTube
    </a>

    <a class="link-btn twitter"
       href="https://x.com/advnarendersh"
       target="_blank">
       Twitter (X)
    </a>

    <a class="link-btn whatsapp-channel"
       href="https://whatsapp.com/channel/0029VbBX1X4AYlUSEuML0w0P"
       target="_blank">
       WhatsApp Channel
    </a>

    <a class="link-btn whatsapp-community"
       href="https://chat.whatsapp.com/HXMMpquDZf6BPt2cJLRmlL"
       target="_blank">
       WhatsApp Community
    </a>

    <a class="link-btn threads"
       href="https://www.threads.com/@adv.narendersh"
       target="_blank">
       Threads
    </a>

    <footer>
        Follow, Like, Share & Subscribe
    </footer>

</div>

</body>
</html>
